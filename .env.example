# SolRemit — environment template. Copy to .env.local and fill in.
# .env* is gitignored — NEVER commit real keys.

# --- Solana RPC (Helius recommended for prod rate limits) ---
# Get a free key at https://dashboard.helius.dev
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Server-side RPC (kept off the client) — used by API routes
HELIUS_API_KEY=YOUR_HELIUS_KEY

# --- Coinbase Developer Platform (on-ramp + embedded wallets + KYC) ---
# https://portal.cdp.coinbase.com
NEXT_PUBLIC_CDP_PROJECT_ID=YOUR_CDP_PROJECT_ID
CDP_API_KEY_ID=YOUR_CDP_API_KEY_ID
CDP_API_KEY_SECRET=YOUR_CDP_API_KEY_SECRET

# --- Jupiter (FX routing) ---
# Public Jupiter API needs no key for basic use (free lite-api fallback is automatic).
# Set JUPITER_API_KEY to use the metered host (api.jup.ag); optionally override the base URL.
# https://portal.jup.ag
JUPITER_API_KEY=
JUPITER_API_BASE=https://lite-api.jup.ag

# --- MXN off-ramp partner (licensed) — fill when partner is selected ---
OFFRAMP_PARTNER_API_KEY=
OFFRAMP_PARTNER_BASE_URL=

# --- SolRemit revenue: disclosed FX markup ---
# Fee in basis points shown in the breakdown (35 = 0.35%). Default 35 if unset.
SOLREMIT_FEE_BPS=35
# Referral token account that collects the markup on-chain at swap time.
# Leave blank to display the fee without collecting (Jupiter takes a cut when set).
SOLREMIT_FEE_ACCOUNT=
